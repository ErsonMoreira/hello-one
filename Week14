from datetime import date
print(date.today())
class BankAccount:
    def __init__(self, account_name, balance=1000):
        self.acccount_name = account_name
        self.balance = balance
    def deposit(self,amount):
        print(date.today())
        self.balance += amount
        self.display_balance()
    def withdraw(self,amount):
        print(date.today())
        self.balance -= amount
        self.display_balance()
    def display_balance(self):
        print(date.today())
        print(f'You have a balance of: ${self.balance}')
    def next(self):
        action = input('To deposit more, d, To withdraw, w, To end transaction, n: ' )
        if action == 'w':
            less = int(input('How much would you like to withdraw: $'))
            self.withdraw(less)  
        elif action == 'd':
            add = int(input('How much would you like to deposit: $'))
            self.deposit(add)
        else:
            self.display_balance()
