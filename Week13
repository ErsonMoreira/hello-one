#3.) The Character Creator
#  Create a Hero class with name and health (default 100).
#    Add a method take_damage(self, amount) that subtracts the amount from health.
#    Create two heroes and make a simple script where Hero A "attacks" Hero B by calling Hero B's take_damage method.
class Hero:
    def __init__(self, name, health=100):
        self.name = name
        self.health = health

    def take_damage(self, amount):
        self.health -= amount
        print(f'{self.name} is losing health! {self.health}')

ahero = Hero("Hercules")
bhero = Hero("Perseus")
print(f'{ahero.name} attacks {bhero.name}')
bhero.take_damage(25)
