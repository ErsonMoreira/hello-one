#3.) Given two sets:
 #   set1 = {10, 11, 12, 13, 14, 15}  
  #  set2 = {10, 14, 15, 16, 17, 18}  
#
 #   Write Python code to:
  #      Find and print the intersection of set1 and set2.
   #     Find and print the union of set1 and set2.
    #    Find and print the difference between set1 and set2 (elements in set1 but not in set2).
def main():
    set1 = {10, 11, 12, 13, 14, 15}  
    set2 = {10, 14, 15, 16, 17, 18}
    inner = intersect(set1,set2)
    gammon = join(set1,set2)
    diff = alt(set1,set2)
    print(f'The intersection is: {inner}')
    print(f'The union is: {gammon}')
    print(f'The difference is: {diff}')

def intersect(a,b):
    #bet = a.intersection(b)
    bet = a & b
    return bet

def join(x,y):
    #whole = x|y
    whole = x.union(y)
    return whole

def alt(s,f):
    #less = s.difference(f)
    less = s - f
    return less
    
main()
